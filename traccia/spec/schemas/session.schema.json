{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traccia.dev/schemas/session.schema.json",
  "title": "Session",
  "description": "一个完整目标的执行上下文",
  "type": "object",
  "required": ["session_id", "objective", "started_at", "status"],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed", "cancelled"]
    }
  },
  "additionalProperties": false
}